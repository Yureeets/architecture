[flake8]
max-line-length = 120

# Глобальні ігнори (стосуються всіх файлів)
extend-ignore =
    # Пробіли у порожніх рядках — стилістика
    W293,
    W291,
    # Довжина рядка (дублюється max-line-length, але на всяк випадок)
    E501,
    W503

per-file-ignores =
    # Існуючий код з попередніх лаб — ігноруємо стилістичні проблеми
    src/*.py:
        F401,
        E302,
        E303,
        E305,
        E402,
        F541,
